PORT=5000

MONGO_URI=

RESEND_API_KEY=

EVENTBRITE_API_KEY=

MEETUP_API_KEY=

MONDAY_API_KEY=

APOLLO_API_KEY=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

META_APP_ID=
META_APP_SECRET=

X_API_KEY=
X_API_SECRET=

# Jarvis is fully functional with its verified workspace summaries by default.
# Enable an OpenAI-written response only after you intentionally provide a key.
OPENAI_API_KEY=
JARVIS_OPENAI_ENABLED=false
JARVIS_OPENAI_MODEL=gpt-4.1-mini

# Point this at the root of your local Obsidian vault. Jarvis writes notes only
# when both the path is set and this explicit opt-in is true.
OBSIDIAN_VAULT_PATH=
JARVIS_OBSIDIAN_MEMORY_ENABLED=false

# Deployed Jarvis memory: set source to cloud on Render. The local bridge uses
# this secret to push approved Markdown notes from your Mac to MongoDB.
JARVIS_MEMORY_SOURCE=local
JARVIS_MEMORY_SYNC_SECRET=
